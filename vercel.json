{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://vu-universe-backend.onrender.com/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://vu-universe-backend.onrender.com/uploads/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
